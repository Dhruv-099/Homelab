### Example environment variables for this homelab
# Copy this to `.env` and fill values. DO NOT commit `.env` to GitHub.

# Forgejo
FORGEJO_DB_PASSWORD=change_me
FORGEJO_DATA_DIR=./forgejo
FORGEJO_PGDATA_DIR=./postgres

# Nextcloud
NEXTCLOUD_DB_PASSWORD=change_me
NEXTCLOUD_ADMIN_PASSWORD=change_me
NEXTCLOUD_TRUSTED_DOMAIN=cloud.example.com
NEXTCLOUD_DATA_DIR=./nextcloud_data

# Vaultwarden
VAULTWARDEN_ADMIN_TOKEN=change_me
VAULTWARDEN_DOMAIN=https://vault.example.com
VAULTWARDEN_DATA_DIR=./vaultwarden

# Media libraries (shared)
MEDIA_DIR=./media
NAVIDROME_MUSIC_DIR=./music

# Immich (already uses env vars)
DB_PASSWORD=change_me
DB_USERNAME=immich
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=./immich_db
UPLOAD_LOCATION=./immich_uploads

# Notifier (Telegram alerts via Beszel + Watchtower)
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_CHAT_ID=change_me
BESZEL_URL=http://beszel:8090
BESZEL_EMAIL=change_me
BESZEL_PASSWORD=change_me